            // FenÃŠtre glissante pour gÃĐrer les dÃĐcalages de l'espace (non-linÃĐaritÃĐ)
            $bestSim = $immediateSim; $bestMatch = ['type' => 'advance_both', 'offset' => 0];
            for ($offset = 1; $offset <= $maxLookahead; $offset++) {
                if ($i + $offset < $len1) {
