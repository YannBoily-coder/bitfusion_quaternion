        $q1 = $this->encodeToQuaternion($cp1);
        $q2 = $this->encodeToQuaternion($cp2);
        
        $distance = $this->quaternionDistance($q1, $q2);
        $diffRatio = abs($cp1 - $cp2) / 0x110000;
        
        // Amplification de l'ÃĐcart spectral pour briser les arrondis de prÃĐcision
        $structuralIndex = 1.0 - ($distance / M_PI) - ($diffRatio * 40.0);
        
        return max(0.0, $structuralIndex);
    }

