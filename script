 */
class TextElement implements VectorizableInterface {
    private string $text;
    public function __construct(string $text) { $this->text = $text; }
    public function toSpectrogram(): array {
        return array_map('mb_ord', mb_str_split($this->text, 1, 'UTF-8'));
    }
    public function getCategoryOf(int $index): string {
        $spec = $this->toSpectrogram();
        $cp = $spec[$index] ?? 0;
        if ($cp >= 65 && $cp <= 90) return 'LatinUpper';
        if ($cp >= 97 && $cp <= 122) return 'LatinLower';
        return 'Other';
    }
}
