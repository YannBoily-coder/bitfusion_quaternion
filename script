                    $bA = $this->calculateBaseSimilarity($nextV1, $v2);
                    $simA = (($cat1 === $cat2) ? 0.40 + 0.60 * $bA : 0.10 + 0.15 * $bA) - ($offset * $penaltyPerGap);
                    if ($simA > $bestSim) { $bestSim = $simA; $bestMatch = ['type' => 'skip_str1', 'offset' => $offset]; }
