                $totalScore += $sim;
                $details[] = ['pos' => $pos++, 'v1' => $v1, 'v2' => $v2, 'similarity' => $sim];
                $i++; $j++; continue;
            }

            $base = $this->calculateBaseSimilarity($v1, $v2);
            $immediateSim = ($cat1 === $cat2) ? 0.40 + 0.60 * $base : 0.10 + 0.15 * $base;

            if ($immediateSim > 0.85) {
                $totalScore += $immediateSim;
                $details[] = ['pos' => $pos++, 'v1' => $v1, 'v2' => $v2, 'similarity' => $immediateSim];
                $i++; $j++; continue;
